# Required for AI-generated plans. Without it, the app uses a local fallback planner.
OPENAI_API_KEY=

# The current flagship model. Override with another compatible model if needed.
OPENAI_MODEL=gpt-5.5

# Optional. Defaults to ./data/one.db
DATABASE_PATH=

# Optional support address shown on the Settings page.
SUPPORT_EMAIL=support@onetaskaday.app
